# Local: http://localhost:3000
# Vercel production: https://your-domain.com or https://your-project.vercel.app
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
# Optional explicit guardrail: enforce all Supabase credentials point to this project ref.
TONEFEX_EXPECTED_SUPABASE_PROJECT_REF=
# Set to true only after Google is enabled in Supabase Auth providers.
NEXT_PUBLIC_GOOGLE_AUTH_ENABLED=false

# Paid-access bypass for testing. Comma-separated. Keep this limited in production.
TEST_ACCESS_EMAILS=you@example.com

# Dodo Payments
DODO_PAYMENTS_API_KEY=
DODO_PAYMENTS_WEBHOOK_KEY=
DODO_PAYMENTS_ENVIRONMENT=test_mode
# Local: http://localhost:3000/checkout/success
# Vercel production: https://your-domain.com/checkout/success
DODO_PAYMENTS_RETURN_URL=http://localhost:3000/checkout/success
DODO_BEGINNER_MONTHLY_PRODUCT_ID=
DODO_BEGINNER_ANNUAL_PRODUCT_ID=
DODO_EXPERT_MONTHLY_PRODUCT_ID=
DODO_EXPERT_ANNUAL_PRODUCT_ID=

# OpenAI
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-nano
AI_INGESTION_MODEL=gpt-4.1-nano
AI_INGESTION_EMBEDDINGS_ENABLED=false
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
# Optional server-only secret for cron/background workers calling /api/admin/ai-ingestion/run-worker.
AI_INGESTION_WORKER_SECRET=

# Tone core
# Hybrid core is the default runtime behavior. Set `legacy_ai` to force full AI generation.
TONE_GENERATION_MODE=hybrid_core
# Optional override for older deployments that still reference the resolver flag directly.
TONE_CORE_RESOLVER=true

# Music search
MUSIC_SEARCH_COUNTRY=IN
MUSIC_SEARCH_RESULT_LIMIT=30
# Only use this locally if your Windows/Node certificate store blocks Apple's public search API.
MUSIC_SEARCH_ALLOW_INSECURE_TLS=false

# Early tester mode: when true, new users get 3 free adaptations and see
# a feedback form instead of the paywall after exhausting them.
NEXT_PUBLIC_EARLY_TESTER_MODE=false

# Admin notification email for early tester feedback submissions.
ADMIN_NOTIFICATION_EMAIL=

# Optional analytics
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=
