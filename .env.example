# Local: http://localhost:3000
# Vercel production: https://your-domain.com or https://your-project.vercel.app
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
# Set to true only after Google is enabled in Supabase Auth providers.
NEXT_PUBLIC_GOOGLE_AUTH_ENABLED=false

# Paid-access bypass for testing. Comma-separated. Keep this limited in production.
TEST_ACCESS_EMAILS=you@example.com

# Dodo Payments
DODO_PAYMENTS_API_KEY=
DODO_PAYMENTS_WEBHOOK_KEY=
DODO_PAYMENTS_ENVIRONMENT=test_mode
# Local: http://localhost:3000/checkout/success
# Vercel production: https://your-domain.com/checkout/success
DODO_PAYMENTS_RETURN_URL=http://localhost:3000/checkout/success
DODO_BEGINNER_MONTHLY_PRODUCT_ID=
DODO_BEGINNER_ANNUAL_PRODUCT_ID=
DODO_EXPERT_MONTHLY_PRODUCT_ID=
DODO_EXPERT_ANNUAL_PRODUCT_ID=

# OpenAI
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-nano

# Music search
MUSIC_SEARCH_COUNTRY=IN
MUSIC_SEARCH_RESULT_LIMIT=30
# Only use this locally if your Windows/Node certificate store blocks Apple's public search API.
MUSIC_SEARCH_ALLOW_INSECURE_TLS=false

# Optional analytics
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=
